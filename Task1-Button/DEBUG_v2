// ======================================================
// HELPERS (unchanged behavior)
// ======================================================

function toPrintableString(record, fieldName) {
  if (record.getCellValueAsString) {
    const s = record.getCellValueAsString(fieldName);
    return (s && String(s).trim().length > 0) ? String(s) : "";
  }

  const v = record.getCellValue(fieldName);
  if (v === null || v === undefined) return "";
  if (typeof v === "string") return v.trim().length ? v : "";
  if (typeof v === "number" || typeof v === "boolean") return String(v);

  try {
    const s = JSON.stringify(v);
    return s && s !== "{}" && s !== "[]" ? s : "";
  } catch {
    return "";
  }
}

function attachmentCount(record, fieldName) {
  const v = record.getCellValue(fieldName);
  if (!v) return 0;
  if (Array.isArray(v)) return v.length;
  if (typeof v === "object") return 1;
  return 0;
}

function printField(label, value) {
  output.text(`• ${label}: ${value && value.trim().length ? value : "EMPTY"}`);
}

function sanitizeAttachments(att) {
  if (!att) return [];
  const arr = Array.isArray(att) ? att : [att];
  return arr
    .map(a => ({
      title: a.title ?? a.filename ?? a.name,
      url: a.url,
      mimetype: a.mimetype,
      size: a.size,
    }))
    .filter(a => a.url);
}

function isEmptyCell(v) {
  if (v === null || v === undefined) return true;
  if (typeof v === "string") return v.trim().length === 0;
  if (Array.isArray(v)) return v.length === 0;
  return false;
}

async function fetchRecordById(table, id) {
  const q = await table.selectRecordsAsync();
  return q.records.find(r => r.id === id) || null;
}

async function verifyAndPrint(table, id, fieldName) {
  const rec = await fetchRecordById(table, id);
  if (!rec) {
    output.text(`⚠️ Verify "${fieldName}": could not re-fetch record id=${id}`);
    return;
  }
  const asString = rec.getCellValueAsString
    ? rec.getCellValueAsString(fieldName)
    : JSON.stringify(rec.getCellValue(fieldName));

  output.text(`🔎 Stored "${fieldName}": ${asString || "EMPTY"}`);
}

