async function updateIfNotEmpty(table, recordId, fieldMap) {

  for (const [fieldName, value] of Object.entries(fieldMap)) {

    if (isEmptyCell(value)) {
      output.text(`⚠️ EMPTY — ${fieldName} (skipped)`);
      continue;
    }

    try {
      await table.updateRecordAsync(recordId, { [fieldName]: value });
      output.text(`✅ Updated — ${fieldName}`);
    } catch (err) {
      output.text(`❌ Failed updating — ${fieldName}`);
      output.text(String(err));
    }

  }

}

